// ==================== LEARNING ENGINE ====================

model WorkspaceProfile {
  id               String    @id @default(cuid())
  industry         String?
  subIndustry      String?
  strengths        String[]
  tonePreference   String    @default("professional")
  targetAudience   String?
  commonObjections String[]
  bestPractices    String[]
  websiteUrl       String?
  businessType     String? // ecommerce, local_service, b2b_saas, online_service, real_estate, other
  products         String[]
  usps             String[] // unique selling points
  brandVoice       String?
  campaignerPhone  String?
  analyzedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  workspaceId String    @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model MessagingApproach {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String   @default("general")
  tone        String   @default("professional")
  example     String?
  isGlobal    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  campaignApproaches CampaignApproach[]
  banditArms         BanditArm[]

  @@index([workspaceId])
  @@index([isGlobal, isActive])
}

model CampaignApproach {
  id          String   @id @default(cuid())
  stepOrder   Int      @default(0)
  confidence  Float    @default(0.5)
  performance Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaignId String
  campaign   Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  approachId String
  approach   MessagingApproach @relation(fields: [approachId], references: [id], onDelete: Cascade)

  @@unique([campaignId, approachId, stepOrder])
  @@index([campaignId])
}

model BanditArm {
  id           String   @id @default(cuid())
  industry     String
  alpha        Float    @default(1)
  beta         Float    @default(1)
  trials       Int      @default(0)
  successes    Int      @default(0)
  avgReplyRate Float    @default(0)
  lastUpdated  DateTime @default(now())

  approachId  String
  approach    MessagingApproach @relation(fields: [approachId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([approachId, industry, workspaceId])
  @@index([workspaceId, industry])
}

model CampaignPerformanceSnapshot {
  id             String   @id @default(cuid())
  totalSent      Int      @default(0)
  totalDelivered Int      @default(0)
  totalRead      Int      @default(0)
  totalReplied   Int      @default(0)
  totalConverted Int      @default(0)
  deliveryRate   Float    @default(0)
  readRate       Float    @default(0)
  replyRate      Float    @default(0)
  conversionRate Float    @default(0)
  snapshotDate   DateTime @default(now())

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, snapshotDate])
}

model SuggestionFeedback {
  id             String   @id @default(cuid())
  suggestionType String
  suggestion     String
  rating         Int?
  wasUsed        Boolean  @default(false)
  comment        String?
  createdAt      DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, suggestionType])
}

// ==================== AI AGENT (WhatsApp Campaigner) ====================

model AgentUser {
  id        String        @id @default(cuid())
  phone     String        @unique
  name      String?
  role      AgentUserRole @default(AGENCY)
  orgId     String?
  userId    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  sessions      AgentSession[]
  approvals     AgentApproval[] @relation("approver")
  bridgeThreads BridgeThread[]

  @@index([orgId])
}

enum AgentUserRole {
  AGENCY
  BRAND
}

model AgentSession {
  id            String   @id @default(cuid())
  title         String?
  workspaceId   String?
  lastMessageAt DateTime @default(now())
  messageCount  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agentUserId String
  agentUser   AgentUser @relation(fields: [agentUserId], references: [id], onDelete: Cascade)

  messages AgentMessage[]

  @@index([agentUserId])
  @@index([agentUserId, workspaceId])
}

model AgentMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  channel   String   @default("whatsapp") // "whatsapp" | "web"
  toolCalls Json?
  createdAt DateTime @default(now())

  sessionId String
  session   AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model AgentApproval {
  id         String         @id @default(cuid())
  token      String         @unique @default(cuid())
  type       String
  status     ApprovalStatus @default(PENDING)
  level      ApprovalLevel
  payload    Json
  summary    String
  imageUrl   String?
  nextAction Json?
  feedback   String?
  expiresAt  DateTime?
  resolvedAt DateTime?
  createdAt  DateTime       @default(now())

  approverId  String
  approver    AgentUser @relation("approver", fields: [approverId], references: [id])
  workspaceId String
  sessionId   String?

  @@index([approverId, status])
  @@index([workspaceId])
  @@index([token])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalLevel {
  AGENCY
  BRAND
}

model BrandContact {
  id          String   @id @default(cuid())
  phone       String
  name        String
  role        String?
  workspaceId String
  createdAt   DateTime @default(now())

  @@unique([phone, workspaceId])
  @@index([workspaceId])
}

model AgentMemory {
  id         String    @id @default(cuid())
  category   String // preference, decision, pattern, constraint, context
  key        String
  value      String
  importance Int       @default(5)
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, category, key])
  @@index([workspaceId, category])
}

// ==================== OPTIMIZER (Agent Lightning) ====================

model OptimizationRecommendation {
  id                   String       @id @default(cuid())
  type                 String // "budget_increase", "budget_decrease", "campaign_pause", "campaign_resume"
  title                String
  description          String
  impact               String       @default("medium")
  category             String // "budget", "bidding", "creative", "performance"
  estimatedImprovement String?
  explanation          String? // Plain-English explanation for business owners
  status               String       @default("pending")
  confidence           Float        @default(0.5)
  payload              Json // { campaignId, action, params }
  appliedAt            DateTime?
  rejectedAt           DateTime?
  outcomeReward        Float?
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  adCampaignId         String?
  adCampaign           AdCampaign?  @relation(fields: [adCampaignId], references: [id], onDelete: Cascade)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  expiresAt            DateTime?

  @@index([organizationId, status])
  @@index([adCampaignId])
}

model AdMetricSnapshot {
  id           String     @id @default(cuid())
  adCampaignId String
  adCampaign   AdCampaign @relation(fields: [adCampaignId], references: [id], onDelete: Cascade)
  adSetId      String?
  impressions  Int        @default(0)
  clicks       Int        @default(0)
  spend        Float      @default(0)
  conversions  Int        @default(0)
  ctr          Float      @default(0)
  cpc          Float      @default(0)
  cpl          Float      @default(0)
  cpm          Float      @default(0)
  roas         Float      @default(0)
  frequency    Float?
  reach        Int?
  snapshotDate DateTime   @default(now())

  @@unique([adCampaignId, snapshotDate])
  @@index([adSetId, snapshotDate])
}

model OptimizerAgent {
  id             String    @id @default(cuid())
  name           String
  config         Json      @default("{}")
  organizationId String
  isActive       Boolean   @default(true)
  lastRunAt      DateTime?
  totalDecisions Int       @default(0)
  avgReward      Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([name, organizationId])
}

// ==================== WHATSAPP BRIDGE (3-Way Relay) ====================

model BridgeThread {
  id     String             @id @default(cuid())
  status BridgeThreadStatus @default(ACTIVE)

  // Customer side
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Campaigner side (agency user who receives relayed messages)
  agentUserId String
  agentUser   AgentUser @relation(fields: [agentUserId], references: [id])

  // Context
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customerName  String?
  customerPhone String
  lastRelayAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  relayMessages BridgeRelayMessage[]

  @@unique([conversationId, agentUserId])
  @@index([agentUserId, status])
  @@index([workspaceId])
  @@index([customerPhone])
}

enum BridgeThreadStatus {
  ACTIVE
  PAUSED
  RESOLVED
}

model BridgeRelayMessage {
  id             String       @id @default(cuid())
  bridgeThreadId String
  bridgeThread   BridgeThread @relation(fields: [bridgeThreadId], references: [id], onDelete: Cascade)

  direction       String // TO_CAMPAIGNER | TO_CUSTOMER
  originalContent String
  relayedContent  String
  sourceMessageId String?
  whatsappId      String?

  createdAt DateTime @default(now())

  @@index([bridgeThreadId, createdAt])
}

// ==================== CREATIVES ====================

model Creative {
  id           String         @id @default(cuid())
  imageUrl     String
  imageId      String // filesystem ID for /api/creative-image/[id]
  status       CreativeStatus @default(DRAFT)
  campaignType String         @default("paid_ad")
  imageSize    String         @default("1:1")
  designStyle  String         @default("luxury")

  // AI-generated copy
  title     String?
  concept   String?
  copyText  String?
  rationale String?

  // Brief inputs
  headline     String?
  subHeadline  String?
  ctaText      String?
  visualPrompt String?

  // Approval tracking
  approvalId     String? // AgentApproval ID for agency-level
  approvalStatus String? // mirrors approval status for quick queries

  // Meta Ads integration
  metaCampaignId String? // Meta campaign ID once launched
  metaCreativeId String? // Meta creative ID once created

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
}

enum CreativeStatus {
  DRAFT
  PENDING_AGENCY
  PENDING_CLIENT
  APPROVED
  REJECTED
  LAUNCHED
}

// ==================== GOOGLE ADS: KEYWORDS ====================

model Keyword {
  id             String   @id @default(cuid())
  text           String
  matchType      String // BROAD, PHRASE, EXACT
  isNegative     Boolean  @default(false)
  status         String   @default("ENABLED") // ENABLED, PAUSED, REMOVED
  qualityScore   Int?
  expectedCtr    String? // ABOVE_AVERAGE, AVERAGE, BELOW_AVERAGE
  adRelevance    String?
  landingPageExp String?
  maxCpcMicros   BigInt? // bid override in micros
  adGroupId      String // links to AdSet (which serves as ad group for Google)
  adGroup        AdSet    @relation(fields: [adGroupId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([adGroupId])
}

// ==================== GOOGLE ADS: AD ASSETS ====================

model AdAsset {
  id         String  @id @default(cuid())
  type       String // SITELINK, CALLOUT, STRUCTURED_SNIPPET, CALL, IMAGE, VIDEO, HEADLINE, DESCRIPTION
  platformId String? // Google asset resource name

  // Sitelink fields
  headline     String?
  description1 String?
  description2 String?
  finalUrl     String?

  // Callout/Snippet fields
  text   String?
  header String? // for structured snippets
  values String[] // for structured snippet values

  // Media fields
  imageUrl String?
  videoUrl String?

  // Scope
  level          String      @default("CAMPAIGN") // ACCOUNT, CAMPAIGN, AD_GROUP
  campaignId     String?
  campaign       AdCampaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  adGroupId      String? // adSet id
  organizationId String

  status    String   @default("ENABLED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId])
  @@index([organizationId, type])
}

// ==================== GOOGLE ADS: ASSET GROUPS (PMAX) ====================

model AssetGroup {
  id         String   @id @default(cuid())
  name       String
  platformId String? // Google resource name
  status     String   @default("ENABLED")
  finalUrls  String[]

  // Assets (JSON arrays of asset IDs/URLs)
  headlines     Json // [{text: "...", pinned?: true}]
  longHeadlines Json // [{text: "..."}]
  descriptions  Json // [{text: "..."}]
  images        Json // [{url: "...", type: "LANDSCAPE"|"SQUARE"|"PORTRAIT"}]
  logos         Json // [{url: "..."}]
  videos        Json? // [{youtubeId: "..."}]

  // Audience signals
  audienceSignals Json? // {customSegments: [], inMarket: [], yourData: []}

  campaignId String
  campaign   AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([campaignId])
}
